# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Databricks Configuration
# Get these from your Databricks workspace:
# 1. Server hostname: Settings -> Developer -> SQL Warehouse -> Connection Details
# 2. HTTP path: Settings -> Developer -> SQL Warehouse -> Connection Details  
# 3. Access token: Settings -> User Settings -> Access Tokens -> Generate New Token
DATABRICKS_SERVER_HOSTNAME=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_ACCESS_TOKEN=dapi...your-token-here
DATABRICKS_CATALOG=fma_catalog

# MLflow Configuration
# Option 1: Use Databricks MLflow (recommended if model is in Databricks)
MLFLOW_TRACKING_URI=databricks
# Option 2: Use specific model URI (e.g., from Volumes)
# MLFLOW_MODEL_URI=models:/kmeans_music_clustering/Production
# MLFLOW_MODEL_URI=runs:/your-run-id/spark_kmeans_model

# Databricks Model Serving Configuration (Recommended)
# Set USE_MODEL_SERVING=true to use Databricks Model Serving REST API
# This avoids Spark dependency issues and provides better performance
USE_MODEL_SERVING=true
# The name of your Model Serving endpoint (create in Databricks UI: Machine Learning -> Serving)
MODEL_SERVING_ENDPOINT=kmeans_music_clustering

# AWS S3 Configuration (for audio file storage and access)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=fma-data-bucket
S3_AUDIO_PREFIX=raw_audio/
PRESIGNED_URL_EXPIRATION=3600

# Audio Processing Settings
UPLOAD_FOLDER=static/uploads
